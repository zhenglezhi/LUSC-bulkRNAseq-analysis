```{r}
remove <- c("LC.016C", "LC.040C", "LC.043C", "LC.031N", "LC.041N")
counts_paired <- counts[,!colnames(counts) %in% remove]

dim(counts_paired)

colnames(counts_paired)

```



```{r}
# Clean gene ID (remove version numbers .xx)
counts_paired$gene_id <- gsub("\\..*", "", counts_paired$gene_id)
```


```{r}
# Collapse duplicate gene IDs by summing counts
counts_cleaned <- counts_paired %>%
  group_by(gene_id) %>%
  summarise(across(where(is.numeric), sum)) %>%
  as.data.frame()
```

#filter out low counts
```{r}

head(counts_cleaned)

samples <- counts_cleaned[, -1]

keep <- rowSums(edgeR::cpm(samples)>1) >= 3

counts_filtered <- counts_cleaned[keep,]

head(counts_filtered)

dim(counts_filtered)
dim(counts_cleaned)

```

