```{r}
cf_all <- estimateDisp(cf_all)
```

#Testing for DE genes
```{r}
#pairwise comparison between groups
exactTest()
cf_et <- exactTest(cf_all, pair = c("adjacent", "cancer"))
DE <- topTags(cf_et, n = nrow(cf_et$table))$table
head(DE)
```

```{r}
#total num DGE at FDR < 0.05
de1 <- decideTests(cf_et, adjust.method="BH", p.value=0.05)
summary(de1)

```
```{r}
#differentially expressed genes 
de1tags12 <- rownames(cf_et)[as.logical(de1)]
plotSmear(cf_et, de.tags=de1tags12)
abline(h = c(-0.5, 0.5), col = "blue")
```


#find DE genes based on p-values 
# up and down referring to cancer
```{r}
#genesList <- subset(annot, gene_id %in% counts_filtered$gene_id)

genes_Up <- subset(DE, FDR<0.05 & logFC > 0.5)$gene_name
genes_Down <- subset(DE, FDR<0.05 & logFC < -0.5)$gene_name

genes_Up <- as.data.frame(genes_Up)
genes_Down <- as.data.frame(genes_Down)
